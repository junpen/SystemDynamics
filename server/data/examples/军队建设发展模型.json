        "size": [130, 60]
      }
    },
    {
      "type": "VARIABLE",
      "name": "淘汰率",
      "behavior": {
        "value": "0.06"
      },
      "display": {
        "coordinates": [80, 490],
        "size": [130, 60]
      }
    },
    {
      "type": "VARIABLE",
      "name": "战力衰减率",
      "behavior": {
        "value": "0.15"
      },
      "display": {
        "coordinates": [900, 490],
        "size": [130, 60]
      }
    },
    {
      "type": "CONVERTER",
      "name": "训练效能",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "军事人员",
        "interpolation": "LINEAR",
        "data": [
          [0, 0],
          [50, 0.2],
          [100, 0.3],
          [150, 0.34],
          [200, 0.37],
          [300, 0.4],
          [500, 0.42],
          [1000, 0.44]
        ]
      },
      "display": {
        "coordinates": [490, 290],
        "size": [120, 70]
      }
    },
    {
      "type": "CONVERTER",
      "name": "装备效能",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "武器装备",
        "interpolation": "LINEAR",
        "data": [
          [0, 0],
          [20, 0.3],
          [50, 0.5],
          [100, 0.6],
          [200, 0.67],
          [500, 0.72],
          [1000, 0.75]
        ]
      },
      "display": {
        "coordinates": [490, 490],
        "size": [120, 70]
      }
    },
    {
      "type": "CONVERTER",
      "name": "战略态势因子",
      "behavior": {
        "input": "TIME",
        "interpolation": "LINEAR",
        "data": [
          [0, 1],
          [5, 1.05],
          [10, 1.15],
          [15, 1.35],
          [20, 1.5]
        ]
      },
      "display": {
        "coordinates": [900, 300],
        "size": [120, 70]
      }
    },
    {
      "type": "FLOW",
      "name": "经费投入",
      "from": null,
      "to": "国防经费",
      "behavior": {
        "value": "[经济总量] * [国防投入比]",
        "non_negative": false
      },
      "display": {
        "from_coordinates": [145, 210]
      }
    },
    {
      "type": "FLOW",
      "name": "人员投入",
      "from": "国防经费",
      "to": "军事人员",
      "behavior": {
        "value": "[国防经费] * [人员投入率]",
        "non_negative": false
      },
      "display": {}
    },
    {
      "type": "FLOW",
      "name": "人员退役",
      "from": "军事人员",
      "to": null,
      "behavior": {
        "value": "[军事人员] * [退役率]",
        "non_negative": false
      },
      "display": {
        "to_coordinates": [965, 210]
      }
    },
    {
      "type": "FLOW",
      "name": "装备采购",
      "from": "国防经费",
      "to": "武器装备",
      "behavior": {
        "value": "[国防经费] * [装备投入率]",
        "non_negative": false
      },
      "display": {}
    },
    {
      "type": "FLOW",
      "name": "装备淘汰",
      "from": "武器装备",
      "to": null,
      "behavior": {
        "value": "[武器装备] * [淘汰率]",
        "non_negative": false
      },
      "display": {
        "to_coordinates": [355, 618]
      }
    },
    {
      "type": "FLOW",
      "name": "战力生成",
      "from": null,
      "to": "战斗力",
      "behavior": {
        "value": "([训练效能] * [军事人员] + [装备效能] * [武器装备]) * [战略态势因子]",
        "non_negative": false
      },
      "display": {
        "from_coordinates": [550, 409]
      }
    },
    {
      "type": "FLOW",
      "name": "战力衰减",
      "from": "战斗力",
      "to": null,
      "behavior": {
        "value": "[战斗力] * [战力衰减率]",
        "non_negative": false
      },
      "display": {
        "to_coordinates": [755, 640]
      }
    },
