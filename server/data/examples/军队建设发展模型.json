{
  "name": "军队建设发展模型",
  "description": "展示国防经费、军事人员、武器装备与战斗力之间的系统动力学关系，模拟军队从经费投入到战力生成的完整过程。使用转换器节点表示训练效能、装备效能的非线性关系以及战略态势因子随时间的变化。",
  "engine": "SIMULATION_PACKAGE",
  "simulation": {
    "algorithm": "RK4",
    "time_start": 0,
    "time_length": 20,
    "time_step": 0.5,
    "time_units": "YEARS"
  },
  "elements": [
    {
      "type": "STOCK",
      "name": "国防经费",
			
      "behavior": {
        "initial_value": 1000,
        "non_negative": true
      },
      "display": {
        "coordinates": [280, 180],
        "size": [150, 60]
      }
    },
    {
      "type": "STOCK",
      "name": "军事人员",
      "behavior": {
        "initial_value": 100,
        "non_negative": true
      },
      "display": {
        "coordinates": [680, 180],
        "size": [150, 60]
      }
    },
    {
      "type": "STOCK",
      "name": "武器装备",
      "behavior": {
        "initial_value": 50,
        "non_negative": true
      },
      "display": {
        "coordinates": [280, 420],
        "size": [150, 60]
      }
    },
    {
      "type": "STOCK",
