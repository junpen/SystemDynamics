{"name":"军备竞赛模型 (Richardson)","description":"理查森军备竞赛模型 - 两国武器库扩张与裁减的动态博弈","engine":"SIMULATION_PACKAGE","simulation":{"algorithm":"RK4","time_start":0,"time_length":40,"time_step":0.2,"time_units":"YEARS"},"elements":[{"type":"STOCK","name":"RedArsenal","behavior":{"initial_value":200,"non_negative":true},"display":{"coordinates":[200,280],"size":[130,50]}},{"type":"STOCK","name":"BlueArsenal","behavior":{"initial_value":150,"non_negative":true},"display":{"coordinates":[550,280],"size":[130,50]}},{"type":"VARIABLE","name":"RedThreatFactor","behavior":{"value":"0.6"},"display":{"coordinates":[350,100],"size":[130,50]}},{"type":"VARIABLE","name":"BlueThreatFactor","behavior":{"value":"0.5"},"display":{"coordinates":[350,460],"size":[130,50]}},{"type":"VARIABLE","name":"RedFatigue","behavior":{"value":"0.55"},"display":{"coordinates":[50,180],"size":[110,50]}},{"type":"VARIABLE","name":"BlueFatigue","behavior":{"value":"0.45"},"display":{"coordinates":[680,180],"size":[110,50]}},{"type":"VARIABLE","name":"RedGrievance","behavior":{"value":"10"},"display":{"coordinates":[50,380],"size":[110,50]}},{"type":"VARIABLE","name":"BlueGrievance","behavior":{"value":"8"},"display":{"coordinates":[680,380],"size":[110,50]}},{"type":"FLOW","name":"RedArmsBuild","from":null,"to":"RedArsenal","behavior":{"value":"[RedThreatFactor] * [BlueArsenal] + [RedGrievance]","non_negative":true},"display":{"from_coordinates":[100,280],"to_coordinates":[200,280]}},{"type":"FLOW","name":"BlueArmsBuild","from":null,"to":"BlueArsenal","behavior":{"value":"[BlueThreatFactor] * [RedArsenal] + [BlueGrievance]","non_negative":true},"display":{"from_coordinates":[680,280],"to_coordinates":[550,280]}},{"type":"FLOW","name":"RedArmsReduce","from":"RedArsenal","to":null,"behavior":{"value":"[RedFatigue] * [RedArsenal]","non_negative":true},"display":{"from_coordinates":[200,305],"to_coordinates":[100,350]}},{"type":"FLOW","name":"BlueArmsReduce","from":"BlueArsenal","to":null,"behavior":{"value":"[BlueFa