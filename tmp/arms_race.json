{"name":"军备竞赛模型 (Richardson)","description":"理查森军备竞赛模型 - 两国武器库扩张与裁减的动态博弈","engine":"SIMULATION_PACKAGE","simulation":{"algorithm":"RK4","time_start":0,"time_length":40,"time_step":0.2,"time_units":"YEARS"},"elements":[{"type":"STOCK","name":"红军武库","behavior":{"initial_value":200,"non_negative":true},"display":{"coordinates":[200,280],"size":[130,50]}},{"type":"STOCK","name":"蓝军武库","behavior":{"initial_value":150,"non_negative":true},"display":{"coordinates":[550,280],"size":[130,50]}},{"type":"VARIABLE","name":"红军威胁系数","behavior":{"value":"0.6"},"display":{"coordinates":[350,100],"size":[130,50]}},{"type":"VARIABLE","name":"蓝军威胁系数","behavior":{"value":"0.5"},"display":{"coordinates":[350,460],"size":[130,50]}},{"type":"VARIABLE","name":"红军疲劳系数","behavior":{"value":"0.55"},"display":{"coordinates":[50,180],"size":[110,50]}},{"type":"VARIABLE","name":"蓝军疲劳系数","behavior":{"value":"0.45"},"display":{"coordinates":[680,180],"size":[110,50]}},{"type":"VARIABLE","name":"红军野心常数","behavior":{"value":"10"},"display":{"coordinates":[50,380],"size":[110,50]}},{"type":"VARIABLE","name":"蓝军野心常数","behavior":{"value":"8"},"display":{"coordinates":[680,380],"size":[110,50]}},{"type":"FLOW","name":"红军扩军","from":null,"to":"红军武库","behavior":{"value":"[红军威胁系数] * [蓝军武库] + [红军野心常数]","non_negative":true},"display":{"from_coordinates":[100,280],"to_coordinates":[200,280]}},{"type":"FLOW","name":"蓝军扩军","from":null,"to":"蓝军武库","behavior":{"value":"[蓝军威胁系数] * [红军武库] + [蓝军野心常数]","non_negative":true},"display":{"from_coordinates":[680,280],"to_coordinates":[550,280]}},{"type":"FLOW","name":"红军裁军","from":"红军武库","to":null,"behavior":{"value":"[红军疲劳系数] * [红军武库]","non_negative":true},"display":{"from_coordinates":[200,305],"to_coordinates":[100,350]}},{"type":"FLOW","name":"蓝军裁军","from":"蓝军武库","to":null,"behavior":{"value":"[蓝军疲劳系数] * [蓝军武库]","non_negative":true},"display":{"from_coordinates":[550,305],"to_coordinates":[680,350]}},{"type":"LINK","name":"","from":"蓝军武库","to":"红军扩军","behavior":{}},{"t